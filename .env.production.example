# Production Environment Variables
# Copy this file to .env.production and fill in your values

# === Database (PostgreSQL for production) ===
DATABASE_URL=postgresql://user:password@host:5432/myshop

# === NextAuth Configuration ===
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=https://yourdomain.com

# === Stripe Configuration ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_public_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# === Site Configuration ===
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=My Shop

# === Email Configuration (SendGrid Example) ===
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASSWORD=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_SECURE=true

# === Redis (Optional - for caching) ===
REDIS_URL=redis://user:password@host:6379

# === Monitoring (Optional) ===
SENTRY_DSN=your_sentry_dsn_for_error_tracking
ANALYTICS_KEY=your_analytics_key
