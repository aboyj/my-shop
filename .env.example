# Database - PostgreSQL (Supabase, Railway, or other provider)
# For production, use a managed PostgreSQL service
# Local: postgresql://user:password@localhost:5432/myshop
# Supabase: postgresql://[user]:[password]@[host].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth Configuration
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-secure-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"  # Change to your domain in production

# Stripe Keys
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_/sk_test_ for development
# Use pk_live_/sk_live_ for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_51234567890"
STRIPE_SECRET_KEY="sk_test_01234567890"
STRIPE_WEBHOOK_SECRET="whsec_test_01234567890"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"  # Change to your domain
NEXT_PUBLIC_SITE_NAME="My Shop"

# Optional Features (add as needed)
# NEXT_PUBLIC_ANALYTICS_ID=""
# SENTRY_DSN=""
# POSTHOG_API_KEY=""
