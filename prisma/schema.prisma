generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  password        String?
  image           String?
  bio             String?
  role            String    @default("user")
  suspended       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  products        Product[]
  orders          Order[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  cartItems       CartItem[]
  addresses       Address[]
  profile         UserProfile?
  discountUsages  DiscountUsage[]

  @@index([email])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String
  longDescription String?
  price           Float
  discountPrice   Float?
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  images          Image[]
  tags            Tag[]
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  downloads       Int      @default(0)
  rating          Float    @default(0)
  status          String   @default("draft")
  visibility      String   @default("public")
  featured        Boolean  @default(false)

  fileUrl         String?
  fileName        String?
  fileSize        Int?

  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems      OrderItem[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  cartItems       CartItem[]
  inventory       Inventory?
  discountCodes   DiscountCode[]

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
}

model Category {
  id               String   @id @default(cuid())
  name             String   @unique
  slug             String   @unique
  description      String?
  icon             String?
  featured         Boolean  @default(false)
  order            Int      @default(0)
  products         Product[]
  discountCodes    DiscountCode[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
}

model Image {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Tag {
  id       String   @id @default(cuid())
  name     String   @unique
  products Product[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  items           OrderItem[]
  totalAmount     Float
  subtotal        Float
  tax             Float
  discountAmount  Float    @default(0)
  discountCodeId  String?
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)

  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String

  status          String   @default("pending")
  paymentIntentId String?
  paymentStatus   String   @default("unpaid")
  paymentMethod   String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([paymentIntentId])
  @@index([discountCodeId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model Review {
  id              String   @id @default(cuid())
  rating          Int
  title           String
  content         String
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String   @default("pending")
  helpfulCount    Int      @default(0)
  reportCount     Int      @default(0)
  verifiedPurchase Boolean @default(false)
  images          ReviewImage[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([status])
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  createdAt DateTime @default(now())

  @@index([reviewId])
}

model UserProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber       String?
  dateOfBirth       DateTime?
  profilePhoto      String?
  socialLinks       String?
  preferredLanguage String    @default("en")
  newsletterSubscribed Boolean @default(false)
  verificationStatus String   @default("unverified")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  fullName  String
  street    String
  city      String
  state     String
  zip       String
  country   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model DiscountCode {
  id                   String   @id @default(cuid())
  code                 String   @unique
  type                 String
  value                Float
  maxUses              Int?
  usedCount            Int      @default(0)
  minOrderAmount       Float    @default(0)
  expiresAt            DateTime?
  applicableProducts   Product[]
  applicableCategories Category[]
  usages               DiscountUsage[]
  orders               Order[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([code])
  @@index([expiresAt])
}

model DiscountUsage {
  id         String   @id @default(cuid())
  discountId String
  discount   DiscountCode @relation(fields: [discountId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt     DateTime @default(now())

  @@index([discountId])
  @@index([userId])
}

model Inventory {
  id                String   @id @default(cuid())
  productId         String   @unique
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Int      @default(0)
  reservedCount     Int      @default(0)
  lowStockThreshold Int      @default(10)
  warehouseLocation String?
  logs              InventoryLog[]
  updatedAt         DateTime @updatedAt

  @@index([productId])
}

model InventoryLog {
  id           String   @id @default(cuid())
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  changeType   String
  quantity     Int
  reason       String?
  orderId      String?
  timestamp    DateTime @default(now())

  @@index([inventoryId])
  @@index([orderId])
}

model EmailTemplate {
  id          String    @id @default(cuid())
  name        String    @unique
  subject     String
  htmlContent String
  variables   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EmailLog {
  id             String   @id @default(cuid())
  recipientId    String
  templateName   String
  status         String   @default("sent")
  sentAt         DateTime @default(now())
  failureReason  String?
  orderId        String?

  @@index([recipientId])
  @@index([orderId])
  @@index([status])
}

model PageView {
  id        String   @id @default(cuid())
  userId    String?
  pagePath  String
  referrer  String?
  sessionId String
  viewedAt  DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([viewedAt])
}

model ProductView {
  id           String   @id @default(cuid())
  userId       String?
  productId    String
  viewDuration Int?
  source       String?
  timestamp    DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([timestamp])
}

model Conversion {
  id        String   @id @default(cuid())
  userId    String
  orderId   String
  value     Float
  source    String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([timestamp])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  userId    String?
  productId String?
  metadata  String?
  timestamp DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([productId])
  @@index([timestamp])
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@index([key])
}
